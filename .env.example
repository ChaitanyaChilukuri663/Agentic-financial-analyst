# Copy to `.env` and fill in. Never commit real keys. All vars use the LEDGERLENS_ prefix.

# ---- Provider selection ----
LEDGERLENS_PROVIDER=azure                 # azure | github | groq

# ---- Azure OpenAI (primary) ----
LEDGERLENS_AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
LEDGERLENS_AZURE_OPENAI_API_KEY=
LEDGERLENS_AZURE_OPENAI_API_VERSION=2024-10-21
LEDGERLENS_AZURE_CHAT_DEPLOYMENT=gpt-4o-mini
LEDGERLENS_AZURE_EMBED_DEPLOYMENT=text-embedding-3-small

# ---- GitHub Models (fallback) ----
LEDGERLENS_GITHUB_TOKEN=
LEDGERLENS_GITHUB_CHAT_MODEL=gpt-4o-mini
LEDGERLENS_GITHUB_EMBED_MODEL=text-embedding-3-small

# ---- Groq (fallback; chat only) ----
LEDGERLENS_GROQ_API_KEY=
LEDGERLENS_GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ---- Transport ----
# Trust the OS certificate store (set true behind a TLS-inspecting proxy, e.g. Zscaler).
LEDGERLENS_USE_OS_TRUSTSTORE=true
LEDGERLENS_REQUEST_TIMEOUT_S=60
LEDGERLENS_MAX_RETRIES=2
